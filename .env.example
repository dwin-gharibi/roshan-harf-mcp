# roshan-harf-mcp environment example.
#
# Copy to `.env` and fill in real values:  cp .env.example .env
# `.env` is gitignored. docker-compose loads it via `env_file: .env`.
#
# Harf authenticates via Keycloak SSO: supply USERNAME + PASSWORD and the server
# logs in at POST /auth/glogin/ to obtain a Bearer access token (cached, and
# refreshed on 401). Alternatively, supply a pre-issued TOKEN to skip login.

# ---------------------------------------------------------------------------
# Global
# ---------------------------------------------------------------------------
# Instance used when a tool call omits `instance`.
ROSHAN_HARF__DEFAULT_INSTANCE=default
# Log level: DEBUG / INFO / WARNING / ERROR.
ROSHAN_HARF__LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Default instance (public Harf host)
# ---------------------------------------------------------------------------
ROSHAN_HARF__INSTANCES__DEFAULT__BASE_URL=https://harf.roshan-ai.ir
# Option A: SSO login credentials (preferred).
ROSHAN_HARF__INSTANCES__DEFAULT__USERNAME=your-username
ROSHAN_HARF__INSTANCES__DEFAULT__PASSWORD=your-password
# Option B: a pre-issued access token (used verbatim as 'Bearer <token>').
# ROSHAN_HARF__INSTANCES__DEFAULT__TOKEN=your-access-token
ROSHAN_HARF__INSTANCES__DEFAULT__VERIFY_SSL=true
ROSHAN_HARF__INSTANCES__DEFAULT__TIMEOUT=60

# ---------------------------------------------------------------------------
# Second named instance: shiraz (a self-hosted deployment)
# ---------------------------------------------------------------------------
ROSHAN_HARF__INSTANCES__SHIRAZ__BASE_URL=https://harf.shiraz.example.ir
ROSHAN_HARF__INSTANCES__SHIRAZ__USERNAME=shiraz-username
ROSHAN_HARF__INSTANCES__SHIRAZ__PASSWORD=shiraz-password
# ROSHAN_HARF__INSTANCES__SHIRAZ__TOKEN=shiraz-access-token
# Set to false for on-prem deployments with self-signed certificates.
ROSHAN_HARF__INSTANCES__SHIRAZ__VERIFY_SSL=true
ROSHAN_HARF__INSTANCES__SHIRAZ__TIMEOUT=60

# ---------------------------------------------------------------------------
# Shorthand (single-instance) alternative — synthesizes the `default` instance.
# Use *either* the nested form above *or* this shorthand, not both.
# ---------------------------------------------------------------------------
# ROSHAN_HARF_BASE_URL=https://harf.roshan-ai.ir
# ROSHAN_HARF_USERNAME=your-username
# ROSHAN_HARF_PASSWORD=your-password
# ROSHAN_HARF_TOKEN=your-access-token
